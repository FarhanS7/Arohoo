# -----------------------------------------------------------------------------
# Arohoo Platform - Production Environment Template
# -----------------------------------------------------------------------------
# Copy this file to .env and populate with production secrets.
# DO NOT commit the .env file to version control.

# --- GENERAL ---
NODE_ENV=production
PORT=8000
LOG_LEVEL=info

# --- DATABASE (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/arohoo_prod?schema=public"
# Direct connection string (e.g. for migrations if using a pooler like Prisma Accelerate)
DIRECT_URL="postgresql://postgres:password@localhost:5432/arohoo_prod?schema=public"

# --- SECURITY ---
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-production-key-change-this"
JWT_EXPIRES_IN=7d

# --- FRONTEND (Next.js) ---
# URL of the backend API for client-side fetching
NEXT_PUBLIC_API_URL="https://api.arohoo.com/api/v1"

# --- STORAGE (Future Proofing) ---
# Currently using local storage: public/uploads/
# Placeholder for S3/Cloudinary migration
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- EMAIL / OTP (Future Proofing) ---
# Placeholder for SMTP/SendGrid migration
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@arohoo.com

# --- CORS ---
# Allowed frontend origin (e.g. https://arohoo.com)
CORS_ORIGIN="http://localhost:3000"
